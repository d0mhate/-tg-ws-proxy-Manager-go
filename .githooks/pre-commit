#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

staged=$(git diff --cached --name-only)

has_go=0
has_shell=0
has_readme=0

for f in $staged; do
    case "$f" in
        *.go)
            has_go=1 ;;
        *.sh|*.bats|test/*|scripts/*)
            has_shell=1 ;;
        README.md)
            has_readme=1 ;;
    esac
done

if [ "$has_readme" -eq 1 ]; then
    printf '%s\n' 'pre-commit: README.md changes detected, running make fmt-md'
    make fmt-md
    git add README.md
fi

if [ "$has_go" -eq 0 ] && [ "$has_shell" -eq 0 ]; then
    printf '%s\n' 'pre-commit: no .go/.sh/test changes, skipping tests'
    exit 0
fi

if [ "$has_go" -eq 1 ] && [ "$has_shell" -eq 1 ]; then
    printf '%s\n' 'pre-commit: .go and shell/test changes detected, running make test'
    exec make test
elif [ "$has_go" -eq 1 ]; then
    printf '%s\n' 'pre-commit: .go changes detected, running make test-go'
    exec make test-go
else
    printf '%s\n' 'pre-commit: shell/test changes detected, running make test-shell'
    exec make test-shell
fi
